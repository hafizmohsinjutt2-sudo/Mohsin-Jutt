rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && incoming().uid == request.auth.uid
        && incoming().createdAt == request.time;
      allow update: if isOwner(userId)
        && incoming().uid == request.auth.uid
        && incoming().diff(resource.data).affectedKeys().hasOnly(['displayName', 'language', 'phone', 'location', 'role']);
    }

    // --- Farms Collection ---
    match /farms/{farmId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() 
        && incoming().ownerId == request.auth.uid
        && isValidId(farmId);
      allow update: if isSignedIn() 
        && resource.data.ownerId == request.auth.uid
        && incoming().ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // --- Crops Collection ---
    match /crops/{cropId} {
      // Derived access from farm (Master Gate variant for simplicity in this demo)
      allow read: if isSignedIn(); // In production, we'd check if crop.farmId belongs to user
      allow create: if isSignedIn() && incoming().farmId is string;
      allow update: if isSignedIn();
    }

    // --- Scans Collection ---
    match /scans/{scanId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() 
        && incoming().userId == request.auth.uid
        && incoming().timestamp == request.time;
    }
  }
}
